# HERMES Scanner - API Keys
# Copy this file to .env.local and fill in your API keys

FMP_API_KEY=your_fmp_api_key_here
POLYGON_API_KEY=your_polygon_api_key_here
QUIVER_API_KEY=your_quiver_api_key_here
EODHD_API_KEY=your_eodhd_api_key_here

# Vercel Cron Secret (set this in Vercel dashboard)
CRON_SECRET=your_cron_secret_here

# Redis policy
# true in production recommended (fail-closed when Redis unavailable)
REQUIRE_REDIS=true

# Signal rendering policy
# true = fail-closed (block stale signals), false = warn-only
NEXT_PUBLIC_SIGNAL_FAIL_CLOSED=true

# Ops alert thresholds (percent)
# Cache origin ratio warning/critical thresholds used in admin ops panels
OPS_CACHE_ORIGIN_WARN_PCT=25
OPS_CACHE_ORIGIN_CRITICAL_PCT=40
