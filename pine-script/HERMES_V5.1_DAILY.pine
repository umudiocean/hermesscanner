// This Pine Script™ code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © HERMES INSTITUTIONAL - NASDAQ 200 WEEK V5.1 (DAILY)
// 200 Hafta / 200 Gün / 20 Gün VWAP Kanalları + MFI + ADX Çarpan
// Timeframe: 1 Gün (1D) - Günlük mum verileri ile çalışır
// Puanlama: 0-100 arası | Yüksek = SHORT, Düşük = LONG

//@version=6
indicator("🟣🟠⚪ HERMES NASDAQ 200W V5.1 DAILY", overlay=true, max_bars_back=5000, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════════════════════
// V5.1 DAILY VERSİYON
// ═══════════════════════════════════════════════════════════════════════════════
// Orijinal V5.1 1 Saatlik (1H) timeframe için tasarlandı.
// Bu versiyon 1 Günlük (1D) timeframe için optimize edildi.
//
// Dönüşüm mantığı (1H → Daily):
//   BARS_PER_DAY = 7 (1H'de günlük bar sayısı)
//   200 Hafta = 200 × 5 işgünü = 1000 daily bar (1H'de 5000 bar)
//   200 Gün = 200 daily bar (1H'de 1400 bar)
//   20 Gün = 20 daily bar (1H'de 140 bar)
//
// Tüm periyotlar ÷7 ile dönüştürüldü:
//   VWAP: 5000→1000, 1400→200, 140→20
//   Z-Score: 1500→300, 500→71, 50→7
//   Kalibrasyon: 100→14 (veya 100 bırakılabilir)
//
// Diğer tüm hesaplamalar (TANH, Sigmoid, Ağırlıklar) AYNI kalır.
// ═══════════════════════════════════════════════════════════════════════════════

int MAX_LB = 5000

// ═══════════════════════════════════════════════════════════════════════════════
// KULLANICI AYARLARI
// ═══════════════════════════════════════════════════════════════════════════════

// Görünürlük Ayarları
grp_visual = "👁️ Görünürlük"
show_200w = input.bool(true, "200 Hafta Kanalı Göster", group=grp_visual)
show_200d = input.bool(true, "200 Gün Kanalı Göster", group=grp_visual)
show_20d = input.bool(true, "20 Gün Kanalı Göster", group=grp_visual)
show_vwap_lines = input.bool(true, "VWAP Orta Çizgileri Göster", group=grp_visual)
show_anchors = input.bool(true, "Anchor Çizgileri Göster", group=grp_visual)
show_signals = input.bool(true, "Sinyal Şekilleri Göster", group=grp_visual)
show_table = input.bool(true, "Bilgi Tablosu Göster", group=grp_visual)

// VWAP Periyotları (Daily Timeframe)
grp_vwap = "📈 VWAP Ayarları (Daily Timeframe)"
vwap_200w_len = input.int(1000, "200 Hafta VWAP Periyodu", minval=500, maxval=2000, group=grp_vwap, tooltip="200 hafta × 5 işgünü = 1000 bar")
vwap_200d_len = input.int(200, "200 Gün VWAP Periyodu", minval=100, maxval=500, group=grp_vwap, tooltip="200 işgünü = 200 bar")
vwap_20d_len = input.int(20, "20 Gün VWAP Periyodu", minval=10, maxval=60, group=grp_vwap, tooltip="20 işgünü = 20 bar")

// Hibrit Band Ayarları
grp_hybrid = "🔥 Hibrit Band Ayarları"
atr_length = input.int(14, "ATR Periyodu", minval=5, maxval=50, group=grp_hybrid)
atr_mult_200w = input.float(3.0, "200W ATR Çarpanı", minval=1.0, maxval=6, step=0.1, group=grp_hybrid)
atr_mult_200d = input.float(2.5, "200D ATR Çarpanı", minval=1.0, maxval=5, step=0.1, group=grp_hybrid)
atr_mult_20d = input.float(1.8, "20D ATR Çarpanı", minval=0.5, maxval=4, step=0.1, group=grp_hybrid)

// Bant Metot Ağırlıkları
grp_band_weights = "⚖️ Bant Metot Ağırlıkları"
atr_weight = input.float(0.50, "ATR Ağırlığı", minval=0.3, maxval=0.8, step=0.05, group=grp_band_weights)
calib_weight = input.float(0.30, "Auto Calib Ağırlığı", minval=0.1, maxval=0.5, step=0.05, group=grp_band_weights)
rev_weight = input.float(0.20, "Reversal Ağırlığı", minval=0.05, maxval=0.4, step=0.05, group=grp_band_weights)

// Sinyal Puanlama Ağırlıkları (5 Bileşen)
grp_signal_weights = "🎯 Puanlama Ağırlıkları (Toplam 100)"
weight_200w = input.float(30, "200W Ağırlık %", minval=0, maxval=100, group=grp_signal_weights)
weight_200d = input.float(25, "200D Ağırlık %", minval=0, maxval=100, group=grp_signal_weights)
weight_20d = input.float(15, "20D Ağırlık %", minval=0, maxval=100, group=grp_signal_weights)
weight_mfi = input.float(15, "MFI Ağırlık %", minval=0, maxval=100, group=grp_signal_weights)
weight_rsi = input.float(15, "RSI Ağırlık %", minval=0, maxval=100, group=grp_signal_weights)

// Anchor Çizgi Ayarları
grp_anchor = "📍 Anchor Ayarları"
anchor_back_len = input.int(200, "Geriye Anchor (Bar)", minval=50, maxval=500, group=grp_anchor, tooltip="Daily: 200 bar ≈ 200 gün")
anchor_forward_len = input.int(20, "İleriye Anchor (Bar)", minval=5, maxval=100, group=grp_anchor)
anchor_line_width = input.int(4, "Anchor Çizgi Kalınlığı", minval=1, maxval=10, group=grp_anchor)

// Gösterge Ayarları (RSI + MFI + ADX)
grp_indicators = "📊 Gösterge Ayarları"
rsi_length = input.int(14, "RSI Periyodu", minval=5, maxval=50, group=grp_indicators)
mfi_length = input.int(14, "MFI Periyodu", minval=5, maxval=50, group=grp_indicators)
adx_length = input.int(14, "ADX Periyodu", minval=5, maxval=50, group=grp_indicators)

// ═══════════════════════════════════════════════════════════════════════════════
// RENK AYARLARI
// ═══════════════════════════════════════════════════════════════════════════════

grp_colors = "🎨 Kanal Renkleri"
color_200w_band = input.color(color.white, "200W Kanal Renk", group=grp_colors)
color_200w_vwap = input.color(color.maroon, "200W VWAP Renk (Koyu Kırmızı)", group=grp_colors)
color_200d_band = input.color(color.purple, "200D Kanal Renk (Mor)", group=grp_colors)
color_200d_vwap = input.color(color.red, "200D VWAP Renk (Açık Kırmızı)", group=grp_colors)
color_20d_band = input.color(color.orange, "20D Kanal Renk (Turuncu)", group=grp_colors)
color_20d_vwap = input.color(color.gray, "20D VWAP Renk (Gri)", group=grp_colors)

grp_anchor_colors = "🎨 Anchor Renkleri"
color_anchor_200w = input.color(color.white, "200W Bant Anchor", group=grp_anchor_colors)
color_anchor_200d = input.color(color.purple, "200D Bant Anchor", group=grp_anchor_colors)
color_anchor_20d = input.color(color.orange, "20D Bant Anchor", group=grp_anchor_colors)
color_vwap_anchor_200w = input.color(color.new(color.maroon, 30), "200W VWAP Anchor", group=grp_anchor_colors)
color_vwap_anchor_200d = input.color(color.new(color.red, 30), "200D VWAP Anchor", group=grp_anchor_colors)
color_vwap_anchor_20d = input.color(color.new(color.gray, 30), "20D VWAP Anchor", group=grp_anchor_colors)

// ═══════════════════════════════════════════════════════════════════════════════
// VWAP HESAPLAMA (ta.sum ile - döngü yok, O(1) performans)
// ═══════════════════════════════════════════════════════════════════════════════

float _vol = nz(volume, 1.0)  // Volume yoksa 1 (equal-weighted fallback)

float vwap_200w = nz(math.sum(close * _vol, vwap_200w_len) / math.sum(_vol, vwap_200w_len), close)
float vwap_200d = nz(math.sum(close * _vol, vwap_200d_len) / math.sum(_vol, vwap_200d_len), close)
float vwap_20d = nz(math.sum(close * _vol, vwap_20d_len) / math.sum(_vol, vwap_20d_len), close)

// Veri yeterliliği kontrolü
bool has_enough_200w = bar_index >= vwap_200w_len * 0.5
bool has_enough_200d = bar_index >= vwap_200d_len * 0.5
bool has_enough_20d = bar_index >= vwap_20d_len * 0.5

// ═══════════════════════════════════════════════════════════════════════════════
// ATR BANDS
// ═══════════════════════════════════════════════════════════════════════════════

float atr_value = ta.atr(atr_length)

float atr_upper_200w = vwap_200w + atr_value * atr_mult_200w
float atr_lower_200w = vwap_200w - atr_value * atr_mult_200w

float atr_upper_200d = vwap_200d + atr_value * atr_mult_200d
float atr_lower_200d = vwap_200d - atr_value * atr_mult_200d

float atr_upper_20d = vwap_20d + atr_value * atr_mult_20d
float atr_lower_20d = vwap_20d - atr_value * atr_mult_20d

// ═══════════════════════════════════════════════════════════════════════════════
// AUTO CALIBRATION
// ═══════════════════════════════════════════════════════════════════════════════

int calib_length = 100

var float adaptive_mult_200w = 3.0
var float adaptive_mult_200d = 2.5
var float adaptive_mult_20d = 1.8
var int bars_since_calib = 0

float dev_200w = close - vwap_200w
float dev_200d = close - vwap_200d
float dev_20d = close - vwap_20d

float std_200w = ta.stdev(dev_200w, calib_length)
float std_200d = ta.stdev(dev_200d, calib_length)
float std_20d = ta.stdev(dev_20d, math.min(calib_length, vwap_20d_len * 2))

float _atr_sma_100 = ta.sma(atr_value, 100)

bars_since_calib += 1
if bars_since_calib >= 50
    bars_since_calib := 0
    float _vol_ratio_calib = atr_value / _atr_sma_100
    if _vol_ratio_calib > 1.3
        adaptive_mult_200w := math.min(adaptive_mult_200w + 0.05, 4.0)
        adaptive_mult_200d := math.min(adaptive_mult_200d + 0.05, 3.5)
        adaptive_mult_20d := math.min(adaptive_mult_20d + 0.05, 2.5)
    else if _vol_ratio_calib < 0.7
        adaptive_mult_200w := math.max(adaptive_mult_200w - 0.05, 2.0)
        adaptive_mult_200d := math.max(adaptive_mult_200d - 0.05, 1.8)
        adaptive_mult_20d := math.max(adaptive_mult_20d - 0.05, 1.2)

float calib_upper_200w = vwap_200w + adaptive_mult_200w * std_200w
float calib_lower_200w = vwap_200w - adaptive_mult_200w * std_200w

float calib_upper_200d = vwap_200d + adaptive_mult_200d * std_200d
float calib_lower_200d = vwap_200d - adaptive_mult_200d * std_200d

float calib_upper_20d = vwap_20d + adaptive_mult_20d * std_20d
float calib_lower_20d = vwap_20d - adaptive_mult_20d * std_20d

// ═══════════════════════════════════════════════════════════════════════════════
// REVERSAL POINTS
// ═══════════════════════════════════════════════════════════════════════════════

int pivot_left = 10
int pivot_right = 10

float pivot_high = ta.pivothigh(high, pivot_left, pivot_right)
float pivot_low = ta.pivotlow(low, pivot_left, pivot_right)

var array<float> high_distances = array.new_float(0)
var array<float> low_distances = array.new_float(0)

if not na(pivot_high)
    float dist = pivot_high - vwap_200w[pivot_right]
    if dist > 0
        array.push(high_distances, dist)
        if array.size(high_distances) > 50
            array.shift(high_distances)

if not na(pivot_low)
    float dist = vwap_200w[pivot_right] - pivot_low
    if dist > 0
        array.push(low_distances, dist)
        if array.size(low_distances) > 50
            array.shift(low_distances)

float avg_high_dist = array.size(high_distances) > 5 ? array.avg(high_distances) : atr_value * 3
float avg_low_dist = array.size(low_distances) > 5 ? array.avg(low_distances) : atr_value * 3

float rev_upper_200w = vwap_200w + avg_high_dist
float rev_lower_200w = vwap_200w - avg_low_dist

float rev_upper_200d = vwap_200d + avg_high_dist * 0.8
float rev_lower_200d = vwap_200d - avg_low_dist * 0.8

float rev_upper_20d = vwap_20d + avg_high_dist * 0.5
float rev_lower_20d = vwap_20d - avg_low_dist * 0.5

// ═══════════════════════════════════════════════════════════════════════════════
// HİBRİT BAND HESAPLAMA
// ═══════════════════════════════════════════════════════════════════════════════

float total_w = atr_weight + calib_weight + rev_weight
float norm_atr = atr_weight / total_w
float norm_calib = calib_weight / total_w
float norm_rev = rev_weight / total_w

float upper_200w = atr_upper_200w * norm_atr + calib_upper_200w * norm_calib + rev_upper_200w * norm_rev
float lower_200w = atr_lower_200w * norm_atr + calib_lower_200w * norm_calib + rev_lower_200w * norm_rev

float upper_200d = atr_upper_200d * norm_atr + calib_upper_200d * norm_calib + rev_upper_200d * norm_rev
float lower_200d = atr_lower_200d * norm_atr + calib_lower_200d * norm_calib + rev_lower_200d * norm_rev

float upper_20d = atr_upper_20d * norm_atr + calib_upper_20d * norm_calib + rev_upper_20d * norm_rev
float lower_20d = atr_lower_20d * norm_atr + calib_lower_20d * norm_calib + rev_lower_20d * norm_rev

// ═══════════════════════════════════════════════════════════════════════════════
// TEMAS SİNYALLERİ
// ═══════════════════════════════════════════════════════════════════════════════

bool touch_200w_upper = high >= upper_200w and high[1] < upper_200w[1]
bool touch_200w_lower = low <= lower_200w and low[1] > lower_200w[1]

bool touch_200d_upper = high >= upper_200d and high[1] < upper_200d[1]
bool touch_200d_lower = low <= lower_200d and low[1] > lower_200d[1]

bool touch_20d_upper = high >= upper_20d and high[1] < upper_20d[1]
bool touch_20d_lower = low <= lower_20d and low[1] > lower_20d[1]

// ═══════════════════════════════════════════════════════════════════════════════
// ANCHOR ÇİZGİLERİ
// ═══════════════════════════════════════════════════════════════════════════════

var line anchor_200w_upper_back = na, var line anchor_200w_lower_back = na
var line anchor_200w_upper_fwd = na, var line anchor_200w_lower_fwd = na
var line anchor_200w_vwap_back = na, var line anchor_200w_vwap_fwd = na

var line anchor_200d_upper_back = na, var line anchor_200d_lower_back = na
var line anchor_200d_upper_fwd = na, var line anchor_200d_lower_fwd = na
var line anchor_200d_vwap_back = na, var line anchor_200d_vwap_fwd = na

var line anchor_20d_upper_back = na, var line anchor_20d_lower_back = na
var line anchor_20d_upper_fwd = na, var line anchor_20d_lower_fwd = na
var line anchor_20d_vwap_back = na, var line anchor_20d_vwap_fwd = na

if show_anchors
    line.delete(anchor_200w_upper_back), line.delete(anchor_200w_lower_back)
    line.delete(anchor_200w_upper_fwd), line.delete(anchor_200w_lower_fwd)
    line.delete(anchor_200w_vwap_back), line.delete(anchor_200w_vwap_fwd)
    line.delete(anchor_200d_upper_back), line.delete(anchor_200d_lower_back)
    line.delete(anchor_200d_upper_fwd), line.delete(anchor_200d_lower_fwd)
    line.delete(anchor_200d_vwap_back), line.delete(anchor_200d_vwap_fwd)
    line.delete(anchor_20d_upper_back), line.delete(anchor_20d_lower_back)
    line.delete(anchor_20d_upper_fwd), line.delete(anchor_20d_lower_fwd)
    line.delete(anchor_20d_vwap_back), line.delete(anchor_20d_vwap_fwd)
    
    // 200W Anchor
    if show_200w
        anchor_200w_upper_back := line.new(bar_index - anchor_back_len, upper_200w, bar_index, upper_200w, color=color_anchor_200w, width=anchor_line_width, style=line.style_solid)
        anchor_200w_upper_fwd := line.new(bar_index, upper_200w, bar_index + anchor_forward_len, upper_200w, color=color_anchor_200w, width=anchor_line_width, style=line.style_dashed)
        anchor_200w_lower_back := line.new(bar_index - anchor_back_len, lower_200w, bar_index, lower_200w, color=color_anchor_200w, width=anchor_line_width, style=line.style_solid)
        anchor_200w_lower_fwd := line.new(bar_index, lower_200w, bar_index + anchor_forward_len, lower_200w, color=color_anchor_200w, width=anchor_line_width, style=line.style_dashed)
        if show_vwap_lines
            anchor_200w_vwap_back := line.new(bar_index - anchor_back_len, vwap_200w, bar_index, vwap_200w, color=color_vwap_anchor_200w, width=anchor_line_width, style=line.style_solid)
            anchor_200w_vwap_fwd := line.new(bar_index, vwap_200w, bar_index + anchor_forward_len, vwap_200w, color=color_vwap_anchor_200w, width=anchor_line_width, style=line.style_dashed)
    
    // 200D Anchor
    if show_200d
        anchor_200d_upper_back := line.new(bar_index - anchor_back_len, upper_200d, bar_index, upper_200d, color=color_anchor_200d, width=anchor_line_width, style=line.style_solid)
        anchor_200d_upper_fwd := line.new(bar_index, upper_200d, bar_index + anchor_forward_len, upper_200d, color=color_anchor_200d, width=anchor_line_width, style=line.style_dashed)
        anchor_200d_lower_back := line.new(bar_index - anchor_back_len, lower_200d, bar_index, lower_200d, color=color_anchor_200d, width=anchor_line_width, style=line.style_solid)
        anchor_200d_lower_fwd := line.new(bar_index, lower_200d, bar_index + anchor_forward_len, lower_200d, color=color_anchor_200d, width=anchor_line_width, style=line.style_dashed)
        if show_vwap_lines
            anchor_200d_vwap_back := line.new(bar_index - anchor_back_len, vwap_200d, bar_index, vwap_200d, color=color_vwap_anchor_200d, width=anchor_line_width, style=line.style_solid)
            anchor_200d_vwap_fwd := line.new(bar_index, vwap_200d, bar_index + anchor_forward_len, vwap_200d, color=color_vwap_anchor_200d, width=anchor_line_width, style=line.style_dashed)
    
    // 20D Anchor
    if show_20d
        anchor_20d_upper_back := line.new(bar_index - anchor_back_len, upper_20d, bar_index, upper_20d, color=color_anchor_20d, width=anchor_line_width, style=line.style_solid)
        anchor_20d_upper_fwd := line.new(bar_index, upper_20d, bar_index + anchor_forward_len, upper_20d, color=color_anchor_20d, width=anchor_line_width, style=line.style_dashed)
        anchor_20d_lower_back := line.new(bar_index - anchor_back_len, lower_20d, bar_index, lower_20d, color=color_anchor_20d, width=anchor_line_width, style=line.style_solid)
        anchor_20d_lower_fwd := line.new(bar_index, lower_20d, bar_index + anchor_forward_len, lower_20d, color=color_anchor_20d, width=anchor_line_width, style=line.style_dashed)
        if show_vwap_lines
            anchor_20d_vwap_back := line.new(bar_index - anchor_back_len, vwap_20d, bar_index, vwap_20d, color=color_vwap_anchor_20d, width=anchor_line_width, style=line.style_solid)
            anchor_20d_vwap_fwd := line.new(bar_index, vwap_20d, bar_index + anchor_forward_len, vwap_20d, color=color_vwap_anchor_20d, width=anchor_line_width, style=line.style_dashed)

// ═══════════════════════════════════════════════════════════════════════════════
// GÖRSELLEŞTİRME - VWAP VE BANDLAR
// ═══════════════════════════════════════════════════════════════════════════════

// 200W VWAP ve Bandlar (Beyaz kanal, Koyu Kırmızı VWAP)
plot(show_200w ? vwap_200w : na, "200W VWAP", color=show_vwap_lines ? color_200w_vwap : color.new(color_200w_vwap, 100), linewidth=3)
plot(show_200w ? upper_200w : na, "200W Üst", color=color_200w_band, linewidth=2)
plot(show_200w ? lower_200w : na, "200W Alt", color=color_200w_band, linewidth=2)

// 200D VWAP ve Bandlar (Mor kanal, Açık Kırmızı VWAP)
plot(show_200d ? vwap_200d : na, "200D VWAP", color=show_vwap_lines ? color_200d_vwap : color.new(color_200d_vwap, 100), linewidth=2)
plot(show_200d ? upper_200d : na, "200D Üst", color=color_200d_band, linewidth=1)
plot(show_200d ? lower_200d : na, "200D Alt", color=color_200d_band, linewidth=1)

// 20D VWAP ve Bandlar (Turuncu kanal, Gri VWAP)
plot(show_20d ? vwap_20d : na, "20D VWAP", color=show_vwap_lines ? color_20d_vwap : color.new(color_20d_vwap, 100), linewidth=2)
plot(show_20d ? upper_20d : na, "20D Üst", color=color_20d_band, linewidth=1, style=plot.style_stepline)
plot(show_20d ? lower_20d : na, "20D Alt", color=color_20d_band, linewidth=1, style=plot.style_stepline)

// ═══════════════════════════════════════════════════════════════════════════════
// PUANLAMA SİSTEMİ V5.1 (TANH + MFI + ADX Çarpan)
// ═══════════════════════════════════════════════════════════════════════════════

// --- Göstergeler ---
float rsi_value = ta.rsi(close, rsi_length)
float mfi_value = ta.mfi(hlc3, mfi_length)
float vol_ratio = atr_value / ta.sma(atr_value, 100)

// --- ADX Hesaplama ---
[diplus, diminus, adx_value] = ta.dmi(adx_length, adx_length)

// --- Z-Score Hesaplama (Daily Timeframe Pencereleri) ---
// 1H → Daily dönüşüm: 1500→300, 500→71, 50→7
int zscore_len_200w = math.min(300, bar_index + 1)
int zscore_len_200d = math.min(71, bar_index + 1)
int zscore_len_20d = math.min(7, bar_index + 1)

float _std_200w_raw = ta.stdev(dev_200w, zscore_len_200w)
float _std_200d_raw = ta.stdev(dev_200d, zscore_len_200d)
float _std_20d_raw = ta.stdev(dev_20d, zscore_len_20d)

float std_200w_zscore = zscore_len_200w > 10 ? nz(_std_200w_raw, 0) : 0
float std_200d_zscore = zscore_len_200d > 10 ? nz(_std_200d_raw, 0) : 0
float std_20d_zscore = zscore_len_20d > 3 ? nz(_std_20d_raw, 0) : 0

float zscore_200w = std_200w_zscore != 0 ? dev_200w / std_200w_zscore : 0
float zscore_200d = std_200d_zscore != 0 ? dev_200d / std_200d_zscore : 0
float zscore_20d = std_20d_zscore != 0 ? dev_20d / std_20d_zscore : 0

// --- TANH Dönüşüm (V5.1) ---
f_tanh(float x) =>
    float e2x = math.exp(2.0 * x)
    (e2x - 1.0) / (e2x + 1.0)

f_zscore_to_100(float zs) =>
    50.0 + 50.0 * f_tanh(zs / 1.8)

// RSI ve MFI zaten 0-100 arası, direkt kullan
f_indicator_to_100(float val) =>
    math.max(0.0, math.min(100.0, val))

// --- Bileşen Puanları (5 Bileşen) ---
float point_200w = has_enough_200w ? f_zscore_to_100(zscore_200w) : 50.0
float point_200d = has_enough_200d ? f_zscore_to_100(zscore_200d) : 50.0
float point_20d = has_enough_20d ? f_zscore_to_100(zscore_20d) : 50.0
float point_mfi = f_indicator_to_100(mfi_value)
float point_rsi = f_indicator_to_100(rsi_value)

// --- Ağırlıklı Ortalama (Raw Score) ---
float direction_weight_total = weight_200w + weight_200d + weight_20d + weight_mfi + weight_rsi
float raw_direction_score = (point_200w * weight_200w + point_200d * weight_200d + point_20d * weight_20d + point_mfi * weight_mfi + point_rsi * weight_rsi) / direction_weight_total

// ═══════════════════════════════════════════════════════════════════════════════
// ÇARPANLAR (Filtre Yok - Hepsi Smooth Sigmoid)
// ═══════════════════════════════════════════════════════════════════════════════

// --- ATR Çarpanı (Volatilite Güveni) ---
float atr_carpan = 0.5 + 0.5 / (1.0 + math.exp(-5.0 * (vol_ratio - 0.7)))

// --- ADX Çarpanı (Mean-Reversion Güveni) ---
float adx_carpan = 1.15 - 0.55 / (1.0 + math.exp(-0.15 * (adx_value - 25.0)))

// --- Kombine Kalite Çarpanı ---
float quality = atr_carpan * adx_carpan

// ═══════════════════════════════════════════════════════════════════════════════
// FİNAL SKOR
// ═══════════════════════════════════════════════════════════════════════════════

float total_score = math.max(0.0, math.min(100.0, 50 + (raw_direction_score - 50) * quality))

// --- Asimetrik Sinyal Kademeleri ---
bool is_strong_short = total_score >= 85
bool is_short = total_score >= 60 and total_score < 85
bool is_neutral = total_score > 40 and total_score < 60
bool is_long = total_score > 15 and total_score <= 40
bool is_strong_long = total_score <= 15

string signal_text = is_strong_short ? "STRONG SHORT" : is_short ? "SHORT" : is_long ? "LONG" : is_strong_long ? "STRONG LONG" : "NÖTR"
color signal_color = is_strong_short ? color.red : is_short ? color.orange : is_long ? color.green : is_strong_long ? color.rgb(255, 215, 0) : color.gray

// ═══════════════════════════════════════════════════════════════════════════════
// SİNYAL ŞEKİLLERİ
// ═══════════════════════════════════════════════════════════════════════════════

plotshape(show_signals and is_strong_long and not is_strong_long[1], "STRONG LONG", shape.triangleup, location.belowbar, color.rgb(255, 215, 0), size=size.normal)
plotshape(show_signals and is_strong_short and not is_strong_short[1], "STRONG SHORT", shape.triangledown, location.abovebar, color.red, size=size.normal)

plotshape(show_signals and touch_200w_lower ? low : na, "200W LONG", shape.triangleup, location.belowbar, color_200w_band, size=size.small)
plotshape(show_signals and touch_200w_upper ? high : na, "200W SHORT", shape.triangledown, location.abovebar, color_200w_band, size=size.small)

plotshape(show_signals and touch_200d_lower ? low : na, "200D LONG", shape.triangleup, location.belowbar, color_200d_band, size=size.tiny)
plotshape(show_signals and touch_200d_upper ? high : na, "200D SHORT", shape.triangledown, location.abovebar, color_200d_band, size=size.tiny)

plotshape(show_signals and touch_20d_lower ? low : na, "20D LONG", shape.circle, location.belowbar, color_20d_band, size=size.tiny)
plotshape(show_signals and touch_20d_upper ? high : na, "20D SHORT", shape.circle, location.abovebar, color_20d_band, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════════
// ALARMLAR
// ═══════════════════════════════════════════════════════════════════════════════

alertcondition(is_strong_long and not is_strong_long[1], title="⭐ STRONG LONG", message="HERMES DAILY V5.1: STRONG LONG (Skor ≤ 15)! {{ticker}} @ {{close}}")
alertcondition(is_strong_short and not is_strong_short[1], title="⭐ STRONG SHORT", message="HERMES DAILY V5.1: STRONG SHORT (Skor ≥ 85)! {{ticker}} @ {{close}}")

alertcondition(touch_200w_lower, title="🟢 200W LONG", message="HERMES: 200 Hafta Alt Band TEMAS! {{ticker}} @ {{close}}")
alertcondition(touch_200w_upper, title="🔴 200W SHORT", message="HERMES: 200 Hafta Üst Band TEMAS! {{ticker}} @ {{close}}")

alertcondition(touch_200d_lower, title="🟢 200D LONG", message="HERMES: 200 Gün Alt Band TEMAS! {{ticker}} @ {{close}}")
alertcondition(touch_200d_upper, title="🔴 200D SHORT", message="HERMES: 200 Gün Üst Band TEMAS! {{ticker}} @ {{close}}")

alertcondition(touch_20d_lower, title="🟢 20D LONG", message="HERMES: 20 Gün Alt Band TEMAS! {{ticker}} @ {{close}}")
alertcondition(touch_20d_upper, title="🔴 20D SHORT", message="HERMES: 20 Gün Üst Band TEMAS! {{ticker}} @ {{close}}")

// ═══════════════════════════════════════════════════════════════════════════════
// BİLGİ TABLOSU (5 Bileşen + 2 Çarpan + Toplam + Veri)
// ═══════════════════════════════════════════════════════════════════════════════

var table infoTable = table.new(position.bottom_left, 3, 12, bgcolor=color.new(color.white, 0), border_width=1, frame_width=2, frame_color=color.black)

if show_table
    // --- Bileşen Status Hesaplama ---
    string status_200w = not has_enough_200w ? "⚠️ VERİ YOK" : point_200w > 65 ? "SHORT" : point_200w >= 35 ? "NÖTR" : "LONG"
    string status_200d = not has_enough_200d ? "⚠️ VERİ YOK" : point_200d > 65 ? "SHORT" : point_200d >= 35 ? "NÖTR" : "LONG"
    string status_20d = not has_enough_20d ? "⚠️ VERİ YOK" : point_20d > 65 ? "SHORT" : point_20d >= 35 ? "NÖTR" : "LONG"
    
    color color_200w_st = not has_enough_200w ? color.orange : point_200w > 65 ? color.red : point_200w >= 35 ? color.gray : color.green
    color color_200d_st = not has_enough_200d ? color.orange : point_200d > 65 ? color.red : point_200d >= 35 ? color.gray : color.green
    color color_20d_st = not has_enough_20d ? color.orange : point_20d > 65 ? color.red : point_20d >= 35 ? color.gray : color.green
    
    // MFI status
    string status_mfi = mfi_value > 80 ? "STR SHORT" : mfi_value > 60 ? "SHORT" : mfi_value >= 40 ? "NÖTR" : mfi_value >= 20 ? "LONG" : "STR LONG"
    color color_mfi = mfi_value > 80 ? color.red : mfi_value > 60 ? color.orange : mfi_value >= 40 ? color.gray : mfi_value >= 20 ? color.green : color.rgb(255, 215, 0)
    
    // RSI status
    string status_rsi = rsi_value > 80 ? "STR SHORT" : rsi_value > 60 ? "SHORT" : rsi_value >= 40 ? "NÖTR" : rsi_value >= 20 ? "LONG" : "STR LONG"
    color color_rsi = rsi_value > 80 ? color.red : rsi_value > 60 ? color.orange : rsi_value >= 40 ? color.gray : rsi_value >= 20 ? color.green : color.rgb(255, 215, 0)
    
    // ATR Çarpan status
    string status_atr_c = atr_carpan < 0.60 ? "❌ BEKLE" : atr_carpan < 0.75 ? "⚠️ DİKKAT" : atr_carpan < 0.90 ? "✓ UYGUN" : "✅ İŞLEM"
    color color_atr_c = atr_carpan < 0.60 ? color.red : atr_carpan < 0.75 ? color.orange : atr_carpan < 0.90 ? color.gray : color.green
    
    // ADX Çarpan status
    string status_adx_c = adx_carpan > 1.05 ? "🚀 GÜÇLÜ MR" : adx_carpan > 0.85 ? "✓ UYGUN" : adx_carpan > 0.70 ? "⚠️ TREND" : "❌ GÜÇ TREND"
    color color_adx_c = adx_carpan > 1.05 ? color.rgb(0, 200, 100) : adx_carpan > 0.85 ? color.green : adx_carpan > 0.70 ? color.orange : color.red
    
    // === TABLO ÇİZİMİ ===
    
    // Row 0: Header
    table.cell(infoTable, 0, 0, "📊 HERMES V5.1 DAILY", text_color=color.white, bgcolor=color.new(#1E90FF, 0), text_size=size.small)
    table.cell(infoTable, 1, 0, signal_text, text_color=color.white, bgcolor=signal_color, text_size=size.small)
    table.cell(infoTable, 2, 0, str.tostring(math.round(total_score)), text_color=color.white, bgcolor=signal_color, text_size=size.small)
    
    // Row 1: Separator
    table.cell(infoTable, 0, 1, "───────", text_color=color.gray, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(infoTable, 1, 1, "───────", text_color=color.gray, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(infoTable, 2, 1, "───────", text_color=color.gray, bgcolor=color.new(color.gray, 80), text_size=size.small)
    
    // Row 2: 200W
    table.cell(infoTable, 0, 2, "200W (" + str.tostring(math.round(weight_200w)) + "%)", text_color=color_200w_vwap, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(math.round(point_200w)), text_color=color_200w_st, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 2, 2, status_200w, text_color=color_200w_st, bgcolor=color.white, text_size=size.small)
    
    // Row 3: 200D
    table.cell(infoTable, 0, 3, "200D (" + str.tostring(math.round(weight_200d)) + "%)", text_color=color_200d_band, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(math.round(point_200d)), text_color=color_200d_st, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 2, 3, status_200d, text_color=color_200d_st, bgcolor=color.white, text_size=size.small)
    
    // Row 4: 20D
    table.cell(infoTable, 0, 4, "20D (" + str.tostring(math.round(weight_20d)) + "%)", text_color=color_20d_band, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 1, 4, str.tostring(math.round(point_20d)), text_color=color_20d_st, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 2, 4, status_20d, text_color=color_20d_st, bgcolor=color.white, text_size=size.small)
    
    // Row 5: MFI
    table.cell(infoTable, 0, 5, "MFI (" + str.tostring(math.round(weight_mfi)) + "%)", text_color=color.new(#1E90FF, 0), bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 1, 5, str.tostring(math.round(point_mfi)), text_color=color_mfi, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 2, 5, status_mfi, text_color=color_mfi, bgcolor=color.white, text_size=size.small)
    
    // Row 6: RSI
    table.cell(infoTable, 0, 6, "RSI (" + str.tostring(math.round(weight_rsi)) + "%)", text_color=color.black, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 1, 6, str.tostring(math.round(point_rsi)), text_color=color_rsi, bgcolor=color.white, text_size=size.small)
    table.cell(infoTable, 2, 6, status_rsi, text_color=color_rsi, bgcolor=color.white, text_size=size.small)
    
    // Row 7: ATR Çarpan
    table.cell(infoTable, 0, 7, "ATR ÇARPAN", text_color=color.black, bgcolor=color.new(color.gray, 92), text_size=size.small)
    table.cell(infoTable, 1, 7, "x" + str.tostring(atr_carpan, "#.##"), text_color=color_atr_c, bgcolor=color.new(color.gray, 92), text_size=size.small)
    table.cell(infoTable, 2, 7, status_atr_c, text_color=color_atr_c, bgcolor=color.new(color.gray, 92), text_size=size.small)
    
    // Row 8: ADX Çarpan
    table.cell(infoTable, 0, 8, "ADX ÇARPAN", text_color=color.black, bgcolor=color.new(color.gray, 92), text_size=size.small)
    table.cell(infoTable, 1, 8, "x" + str.tostring(adx_carpan, "#.##"), text_color=color_adx_c, bgcolor=color.new(color.gray, 92), text_size=size.small)
    table.cell(infoTable, 2, 8, status_adx_c, text_color=color_adx_c, bgcolor=color.new(color.gray, 92), text_size=size.small)
    
    // Row 9: Separator
    table.cell(infoTable, 0, 9, "───────", text_color=color.gray, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(infoTable, 1, 9, "───────", text_color=color.gray, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(infoTable, 2, 9, "───────", text_color=color.gray, bgcolor=color.new(color.gray, 80), text_size=size.small)
    
    // Row 10: TOPLAM
    table.cell(infoTable, 0, 10, "TOPLAM", text_color=color.black, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(infoTable, 1, 10, str.tostring(math.round(total_score)) + " / 100", text_color=signal_color, bgcolor=color.new(color.gray, 80), text_size=size.small)
    table.cell(infoTable, 2, 10, signal_text, text_color=signal_color, bgcolor=color.new(color.gray, 80), text_size=size.small)
    
    // Row 11: Veri durumu
    string data_status = "📊 " + str.tostring(bar_index) + " bar"
    color data_color = bar_index >= vwap_200w_len ? color.green : bar_index >= vwap_200d_len ? color.orange : color.red
    table.cell(infoTable, 0, 11, "VERİ", text_color=color.black, bgcolor=color.new(color.gray, 90), text_size=size.tiny)
    table.cell(infoTable, 1, 11, data_status, text_color=data_color, bgcolor=color.new(color.gray, 90), text_size=size.tiny)
    table.cell(infoTable, 2, 11, bar_index >= vwap_200w_len ? "✓ TAM" : bar_index >= vwap_200d_len ? "⚠️ KISMI" : "❌ AZ", text_color=data_color, bgcolor=color.new(color.gray, 90), text_size=size.tiny)
